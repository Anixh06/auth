# Firebase Configuration Example
# Copy this file to .env and fill in your actual Firebase credentials
# Get these values from your Firebase Console -> Project Settings

# Your Firebase API Key
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY

# Your Firebase Auth Domain (format: projectId.firebaseapp.com)
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com

# Your Firebase Project ID
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID

# Your Firebase Storage Bucket (format: projectId.appspot.com)
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com

# Your Firebase Messaging Sender ID
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID

# Your Firebase App ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID